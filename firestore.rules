rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if the caller is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if the caller is the document owner
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Helper: check if the caller is a member of a group
    function isGroupMember(groupId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    // Helper: check if the caller is the group admin
    function isGroupAdmin(groupId) {
      return isAuthenticated() &&
        request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy;
    }

    // Users: only the owner can read/write their own profile
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // Usernames: public read for availability check, write only via profile creation
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Emails: lookup index (require auth to prevent unauthenticated enumeration)
    match /emails/{email} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Tournaments: public read, only creator can write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;

      // Tournament matches subcollection: any authenticated user can read,
      // only the tournament creator can write (writes happen via Admin SDK anyway)
      match /matches/{matchId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() &&
          request.auth.uid == get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy;
        allow delete: if false;
      }
    }

    // Groups: members can read, group creation and join/leave go through server-side API routes
    // (Admin SDK bypasses these rules, so client-side memberUids updates are no longer allowed)
    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if false; // creation happens via /api/groups/create (Admin SDK)
      // Only group admin can update settings (name, settings, etc.)
      // join/leave handled server-side via /api/groups/join (Admin SDK)
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // Predictions: group members can read, only the owning user can write their own prediction
    match /predictions/{predictionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Match predictions: same as predictions
    match /matchPredictions/{predId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Actual results: per-group, only the group admin can write
    match /actualResults/{groupId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isGroupAdmin(groupId);
      allow delete: if false;
    }

    // =================== FANTASY ===================

    // Helper: check if the caller is a league member
    function isLeagueMember(leagueId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/fantasyLeagues/$(leagueId)).data.memberUids;
    }

    // Helper: check if the caller is the league creator (admin)
    function isLeagueAdmin(leagueId) {
      return isAuthenticated() &&
        request.auth.uid == get(/databases/$(database)/documents/fantasyLeagues/$(leagueId)).data.createdBy;
    }

    // Fantasy Leagues: authenticated users can read public leagues, members can read their own
    match /fantasyLeagues/{leagueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      // Members can join (update memberUids), admin can update settings
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        request.auth.uid in resource.data.memberUids
      );
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // Fantasy Auctions: only league members can read, only league admin can write
    match /fantasyAuctions/{leagueId} {
      allow read: if isLeagueMember(leagueId);
      allow create: if isLeagueAdmin(leagueId);
      // Members can update (for bids, passes, holds, selection picks)
      allow update: if isLeagueMember(leagueId);
      allow delete: if isLeagueAdmin(leagueId);
    }

    // Fantasy Squads: league members can read, only squad owner can write
    match /fantasySquads/{squadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Fantasy User Scores: league members can read, system writes via admin SDK or owner
    match /fantasyUserScores/{scoreId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // =================== GLOBAL FLAT COLLECTIONS ===================

    // Matches: any authenticated user can read, writes via Admin SDK
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create, update: if false; // Admin SDK only
      allow delete: if false;
    }

    // Players: any authenticated user can read, writes via Admin SDK
    match /players/{playerId} {
      allow read: if isAuthenticated();
      allow create, update: if false; // Admin SDK only
      allow delete: if false;
    }

    // Match Scorecards: full raw cricket scorecards, any authenticated user can read
    match /matchScorecards/{matchId} {
      allow read: if isAuthenticated();
      allow create, update: if false; // Admin SDK only
      allow delete: if false;
    }

    // Tournament Stats: precomputed materialized view of per-player stats
    // Rebuilt server-side on refresh from matchScorecards (single source of truth)
    match /tournamentStats/{tournamentId} {
      allow read: if isAuthenticated();
      allow create, update: if false; // Admin SDK only
      allow delete: if false;
    }
  }
}
